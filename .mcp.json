{
  "mcpServers": {
    "postman": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-server-postman@latest"
      ],
      "env": {
        "POSTMAN_API_KEY": ""
      }
    },
    "railway": {
      "command": "npx",
      "args": [
        "-y",
        "@railway/mcp-server"
      ]
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    }
  }
}