# ==============================================================================
# SOFIA AI Assistant - Environment Configuration Template
# ==============================================================================
#
# ARCHITECTURE: Supabase Edge Functions + Next.js (local dev only)
# - WhatsApp Bot (SOPHIA): Supabase Edge Function `sophia-bot` (LIVE)
# - AI Proxy: Supabase Edge Function `ai-chat` (LIVE)
# - Next.js App: NOT deployed (local development only)
# - Database: Supabase PostgreSQL (LIVE)
#
# ==============================================================================

# ==============================================================================
# SUPABASE EDGE FUNCTION SECRETS (PRODUCTION - REQUIRED)
# ==============================================================================
# Set these via: supabase secrets set KEY=value --project-ref vceeheaxcrhmpqueudqx
# View current: supabase secrets list --project-ref vceeheaxcrhmpqueudqx

# AI Provider (OpenRouter - proxies to Gemini)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# WhatsApp Integration (WaSenderAPI ~$6/month)
# Get from: https://wasenderapi.com/dashboard
WASEND_API_KEY=...
WASEND_WEBHOOK_SECRET=...  # Generate: openssl rand -base64 32

# Email Sending (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Admin Authentication
# Generate: openssl rand -base64 32
SOPHIA_ADMIN_SECRET=...

# Zyprus Property API (OAuth)
# Get from Zyprus administrator
ZYPRUS_CLIENT_ID=...
ZYPRUS_CLIENT_SECRET=...
ZYPRUS_API_URL=https://dev9.zyprus.com

# Telegram (DISABLED by default)
TELEGRAM_BOT_TOKEN=...
SOPHIA_TELEGRAM_ENABLED=false

# ==============================================================================
# NEXT.JS LOCAL DEVELOPMENT (NOT for production)
# ==============================================================================
# Copy to .env.local for local development

# Authentication (NextAuth)
# Generate: openssl rand -base64 32
AUTH_SECRET=...

# Access gate code
ACCESS_CODE=the8thchakra

# Supabase Connection (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://vceeheaxcrhmpqueudqx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# Database (Session Pooler format from Supabase Dashboard)
POSTGRES_URL=postgresql://postgres.vceeheaxcrhmpqueudqx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Redis (Upstash for rate limiting)
# Get from: https://console.upstash.com
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# Error Tracking (Sentry)
# Get from: https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=qualia-solutions
SENTRY_PROJECT=sofia

# ==============================================================================
# DEPLOYMENT COMMANDS
# ==============================================================================
# Deploy Edge Functions:
#   supabase functions deploy sophia-bot --no-verify-jwt --project-ref vceeheaxcrhmpqueudqx
#
# Set secrets:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-... --project-ref vceeheaxcrhmpqueudqx
#
# View logs:
#   supabase functions logs sophia-bot --project-ref vceeheaxcrhmpqueudqx
#
# Toggle Telegram:
#   supabase secrets set SOPHIA_TELEGRAM_ENABLED=true --project-ref vceeheaxcrhmpqueudqx
