# ============================================
# SOPHIA AI Assistant - Environment Variables
# ============================================
#
# This file documents all required environment variables for local development.
# Copy this file to .env.local and fill in real values (never commit .env.local).
#
# For production Edge Functions, set secrets via:
#   supabase secrets set KEY=value --project-ref vceeheaxcrhmpqueudqx
#
# For Vercel deployment (web app - currently not deployed):
#   Set via Vercel Dashboard → Project Settings → Environment Variables
#

# --------------------------------------------
# AI / LLM
# --------------------------------------------
# OpenRouter API key for AI model access (Gemini 3 Flash via proxy)
# Get from: https://openrouter.ai/keys
# Used by: Edge Functions (sophia-bot), Next.js app
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API key (direct access - legacy, not actively used)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# AI Gateway API key (optional - Cloudflare AI Gateway if enabled)
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here

# --------------------------------------------
# Database
# --------------------------------------------
# Supabase project URL (vceeheaxcrhmpqueudqx)
SUPABASE_URL=https://vceeheaxcrhmpqueudqx.supabase.co

# Supabase anonymous key (public, safe to expose in client-side code)
# Get from: https://supabase.com/dashboard/project/vceeheaxcrhmpqueudqx/settings/api
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (NEVER expose client-side, server-only)
# Get from: https://supabase.com/dashboard/project/vceeheaxcrhmpqueudqx/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase access token for CLI operations (optional, for local development)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# PostgreSQL connection URL (Session Pooler format for Next.js)
# Format: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Get from: https://supabase.com/dashboard/project/vceeheaxcrhmpqueudqx/settings/database
POSTGRES_URL=your_postgres_connection_url_here
DATABASE_URL=your_postgres_connection_url_here

# Next.js public Supabase credentials (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://vceeheaxcrhmpqueudqx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --------------------------------------------
# Authentication (Next.js)
# --------------------------------------------
# NextAuth secret for JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here

# Base URL for auth callbacks (http://localhost:3000 for local dev)
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# WhatsApp Integration
# --------------------------------------------
# WaSenderAPI key for WhatsApp messaging (~$6/month)
# Get from: https://app.wasender.com
# Used by: Edge Functions (sophia-bot)
WASENDER_API_KEY=your_wasender_api_key_here
WASEND_API_KEY=your_wasender_api_key_here

# Webhook secret for HMAC signature verification
# Set the same value in WaSenderAPI webhook configuration
# Generate with: openssl rand -hex 32
WASENDER_WEBHOOK_SECRET=your_webhook_secret_here
WASEND_WEBHOOK_SECRET=your_webhook_secret_here

# WaSender instance ID and personal access token (optional)
WASENDER_INSTANCE_ID=your_wasender_instance_id_here
WASENDER_PERSONAL_ACCESS_TOKEN=your_wasender_personal_access_token_here

# Generic webhook URL (for testing)
WEBHOOK_URL=https://vceeheaxcrhmpqueudqx.supabase.co/functions/v1/sophia-bot

# --------------------------------------------
# Telegram Integration
# --------------------------------------------
# Telegram Bot API token (from @BotFather)
# Get from: https://t.me/BotFather
# Used by: Edge Functions (sophia-bot, telegram-webhook)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram webhook secret for signature verification
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# Telegram group chat ID for lead routing (v1.2 feature)
# Get by adding @RawDataBot to the group
TELEGRAM_ZYPRESS_OTHERS_CHAT_ID=-1001234567890

# Vasya's Telegram user ID for audit response verification (v1.2 feature)
# Get from @userinfobot
VASYA_TELEGRAM_USER_ID=123456789

# Enable/disable Telegram bot (true/false)
# Set via: supabase secrets set SOPHIA_TELEGRAM_ENABLED=false --project-ref vceeheaxcrhmpqueudqx
SOPHIA_TELEGRAM_ENABLED=false

# --------------------------------------------
# Zyprus Property API
# --------------------------------------------
# Zyprus API OAuth client credentials
# Contact Zyprus admin for credentials
# Used by: Edge Functions (sophia-bot), Next.js app
ZYPRUS_CLIENT_ID=your_zyprus_client_id_here
ZYPRUS_CLIENT_SECRET=your_zyprus_client_secret_here

# Zyprus API base URL (dev or production)
ZYPRUS_API_URL=https://dev9.zyprus.com
ZYPRUS_SITE_URL=https://dev9.zyprus.com

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
# Resend API key for transactional email (document delivery)
# Get from: https://resend.com/api-keys
# Used by: Edge Functions (sophia-bot), Next.js app
RESEND_API_KEY=your_resend_api_key_here

# --------------------------------------------
# 3CX Phone System (v1.2 feature)
# --------------------------------------------
# 3CX server URL and credentials for call log audit
# Contact your 3CX administrator for credentials
# Used by: Edge Function (call-audit)
CX3_BASE_URL=https://your-3cx-server.com
CX3_USERNAME=admin_username
CX3_PASSWORD=admin_password

# --------------------------------------------
# Observability
# --------------------------------------------
# Sentry DSN for error tracking (same for Next.js and Edge Functions)
# Get from: https://sentry.io/settings/projects/
# Used by: All environments (client, server, edge)
SENTRY_DSN=https://your_sentry_dsn_here

# Sentry organization and project (for source map uploads)
SENTRY_ORG=qualia-solutions
SENTRY_PROJECT=sophia

# Sentry auth token for automated uploads (CI/CD only)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Logging level (debug/info/warn/error)
LOG_LEVEL=info

# --------------------------------------------
# Cache & Rate Limiting
# --------------------------------------------
# Upstash Redis credentials for caching and rate limiting
# Get from: https://console.upstash.com/
# Used by: Next.js app (currently not deployed)
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here
REDIS_URL=your_upstash_redis_url_here

# --------------------------------------------
# Admin Access
# --------------------------------------------
# Secret for admin panel access (generate with: openssl rand -base64 32)
# Used by: Next.js admin panel (/admin)
SOPHIA_ADMIN_SECRET=your_admin_secret_here
ADMIN_API_KEY=your_admin_api_key_here

# Cron job secret for scheduled tasks (generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here

# --------------------------------------------
# Platform / Runtime
# --------------------------------------------
# Node environment (development/production)
NODE_ENV=development

# Deno deployment ID (auto-set by Supabase in production, leave empty for local)
DENO_DEPLOYMENT_ID=

# Next.js runtime indicator (set automatically)
NEXT_RUNTIME=nodejs

# Vercel environment (set automatically on Vercel)
VERCEL_ENV=development

# Next.js phase (internal use)
NEXT_PHASE=development

# Local development port
PORT=3000

# --------------------------------------------
# AI Configuration
# --------------------------------------------
# Maximum conversation messages to include in context (default: 50)
MAX_CONVERSATION_MESSAGES=50

# ============================================
# TESTING ENVIRONMENT VARIABLES
# ============================================

# Test WhatsApp number for E2E tests
TEST_WHATSAPP_NUMBER=+1234567890

# Test agent phone number
TEST_AGENT_PHONE=+35799123456

# Test webhook URL for integration tests
TEST_WEBHOOK_URL=http://localhost:54321/functions/v1/sophia-bot

# Playwright E2E testing base URL
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# CI environment detection
CI=false
CI_PLAYWRIGHT=false
PLAYWRIGHT=false

# ============================================
# OPTIONAL / FUTURE ENVIRONMENT VARIABLES
# ============================================

# Vercel Blob storage (FUTURE - not currently deployed)
# Get from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# --- Sophia Invoice embed (M8) — separate Supabase project tijadsdysuxkxrpdlecq ---
INVOICE_SUPABASE_URL=https://tijadsdysuxkxrpdlecq.supabase.co
INVOICE_SUPABASE_SERVICE_ROLE=
SUPABASE_INVOICE_BUCKET=invoices
EMAIL_PROVIDER=manual
WHATSAPP_PROVIDER=manual
SOPHIA_BRIDGE_SECRET=

# Accounting WhatsApp GROUP MSISDN (digits, e.g. 35799000000) that issued invoices
# and credit notes are posted to. REQUIRED for group routing — if unset, no group
# message is sent (the app will NOT fall back to anyone's personal number).
INVOICE_ACCOUNTING_GROUP_MSISDN=
