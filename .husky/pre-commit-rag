#!/bin/bash
# Pre-commit hook to prevent RAG issues
# Checks for the 6 common issues that were previously fixed
# Run before allowing commits

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo -e "${YELLOW}Running RAG prevention checks...${NC}"

# Get staged files only
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check"
  exit 0
fi

# ==========================================
# Check 1: Secrets in URLs (BLOCKING)
# ==========================================
echo -e "${YELLOW}[1/6]${NC} Checking for secrets in URLs..."

if echo "$STAGED_FILES" | xargs grep -l '\?.*KEY\|?.*TOKEN\|Bearer.*\${' 2>/dev/null | \
  grep -E '\.(ts|js|tsx|jsx)$'; then
  echo -e "${RED}❌ Staged files contain potential secrets in URLs${NC}"
  echo "Review: grep -n '?.*KEY\|Bearer.*\$' <file>"
  ((ERRORS++))
else
  echo -e "${GREEN}✅${NC} No secrets in URLs"
fi

# ==========================================
# Check 2: Secrets in console.log (WARNING)
# ==========================================
echo -e "${YELLOW}[2/6]${NC} Checking for secrets in console output..."

if echo "$STAGED_FILES" | xargs grep -l 'console.*API_KEY\|console.*OPENROUTER\|console.*RESEND' 2>/dev/null | \
  grep -E '\.(ts|js)$'; then
  echo -e "${YELLOW}⚠️  Staged files may log secrets${NC}"
  ((WARNINGS++))
else
  echo -e "${GREEN}✅${NC} No secrets in console.log"
fi

# ==========================================
# Check 3: Deprecated without plan (WARNING)
# ==========================================
echo -e "${YELLOW}[3/6]${NC} Checking for deprecated code without removal plan..."

DEPRECATED=$(echo "$STAGED_FILES" | xargs grep -l '@deprecated' 2>/dev/null | \
  xargs grep '@deprecated' 2>/dev/null | \
  grep -v 'removal\|migrate\|202[6-9]\|203[0-9]' || true)

if [ ! -z "$DEPRECATED" ]; then
  echo -e "${YELLOW}⚠️  Deprecated without removal plan:${NC}"
  echo "$DEPRECATED"
  ((WARNINGS++))
else
  echo -e "${GREEN}✅${NC} Deprecated code has removal plans"
fi

# ==========================================
# Check 4: Multiple DB clients (BLOCKING)
# ==========================================
echo -e "${YELLOW}[4/6]${NC} Checking for multiple database client instances..."

# Only check if lib/supabase.ts or lib/db.ts is staged
if echo "$STAGED_FILES" | grep -q 'supabase.ts\|db.ts'; then
  DB_FILES=$(echo "$STAGED_FILES" | grep -E 'lib/|supabase/functions' | wc -l)
  if [ "$DB_FILES" -gt 1 ]; then
    echo -e "${RED}❌ Multiple DB-related files modified - verify singleton pattern${NC}"
    ((ERRORS++))
  else
    echo -e "${GREEN}✅${NC} Singleton pattern maintained"
  fi
else
  echo -e "${GREEN}✅${NC} No DB client changes"
fi

# ==========================================
# Check 5: PII in AI prompts (BLOCKING)
# ==========================================
echo -e "${YELLOW}[5/6]${NC} Checking for PII in prompts..."

PROMPT_FILES=$(echo "$STAGED_FILES" | grep -E 'prompts\.ts|prompt\.ts')

if [ ! -z "$PROMPT_FILES" ]; then
  # Check for email patterns
  if echo "$PROMPT_FILES" | xargs grep -l '[a-z0-9._%+-]\+@[a-z0-9.-]\+\.[a-z]' 2>/dev/null | \
    xargs grep -E '[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]' 2>/dev/null | \
    grep -v 'example@\|test@\|sofia@zyprus.com\|info@'; then
    echo -e "${RED}❌ Email addresses in prompts - use UUID/ID instead${NC}"
    ((ERRORS++))
  else
    echo -e "${GREEN}✅${NC} No email addresses in prompts"
  fi

  # Check for phone patterns
  if echo "$PROMPT_FILES" | xargs grep -E '\+[0-9]{8,15}' 2>/dev/null; then
    echo -e "${RED}❌ Phone numbers in prompts - use UUID/ID instead${NC}"
    ((ERRORS++))
  else
    echo -e "${GREEN}✅${NC} No phone numbers in prompts"
  fi
else
  echo -e "${GREEN}✅${NC} No prompt files staged"
fi

# ==========================================
# Check 6: Blocking operations (INFO)
# ==========================================
echo -e "${YELLOW}[6/6]${NC} Checking for blocking operation patterns..."

# Check for await in loops (soft warning)
if echo "$STAGED_FILES" | xargs grep -B2 -A2 'for.*{\|forEach.*{\|\.map(' 2>/dev/null | \
  grep -q 'await fetch\|await supabase'; then
  echo -e "${YELLOW}ℹ️  Detected await in loop - verify it's intentional or use Promise.all${NC}"
fi

echo -e "${GREEN}✅${NC} Blocking operation check passed"

# ==========================================
# Summary and exit
# ==========================================
echo -e "\n=========================================="
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}❌ Pre-commit checks FAILED (${ERRORS} errors)${NC}"
  echo "Fix errors before committing. Use --no-verify to skip (not recommended)."
  exit 1
fi

if [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}⚠️  Pre-commit checks passed with ${WARNINGS} warning(s)${NC}"
  echo "Review warnings before committing."
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
